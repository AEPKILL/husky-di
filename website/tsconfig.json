{
	"include": ["**/*.ts", "**/*.tsx", "**/*.d.ts", "**/*.mdx"],
	"compilerOptions": {
		"strict": true,
		"esModuleInterop": true,
		"jsx": "react-jsx",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"lib": ["DOM", "DOM.Iterable", "ES2024"],
		"isolatedModules": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"target": "ES2024",
		"forceConsistentCasingInFileNames": true,
		"noEmit": true,
		"paths": {
			"@/*": ["./src/*"]
		}
	}
}
