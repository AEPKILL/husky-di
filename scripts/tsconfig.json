{
	"compilerOptions": {
		"lib": ["ES2023"],
		"module": "ESNext",
		"target": "ES2022",
		"noEmit": true,
		"strict": true,
		"skipLibCheck": true,
		"moduleResolution": "bundler",
		"types": ["node"],
		"allowImportingTsExtensions": true,
		"baseUrl": ".",
		"paths": {
			"@/*": ["src/*"]
		},
		"ignoreDeprecations": "6.0"
	},
	"include": ["."]
}
